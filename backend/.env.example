# Backend debug/runtime settings. Copy to backend/.env for direct Python runs.

# Local self-hosted Supabase:
# SUPABASE_URL=http://host.docker.internal:8000
#
# Supabase online:
# SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_URL=http://host.docker.internal:8000
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Common settings:
USERNAME=admin@phoenine.top
PASSWORD=WxHelper@2025!
CACHE_DIR=./data/cache
SPAN_INTERVAL=10

# LLM settings for online testing.
LLM_API_BASE=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=120

OCR_ENABLED=false
OCR_API_BASE=
OCR_MODEL=
OCR_API_KEY=
OCR_REQUEST_TIMEOUT_SECONDS=60
