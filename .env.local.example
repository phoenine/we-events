# Docker Compose settings for local self-hosted Supabase.
COMPOSE_PROJECT_NAME=we-events
THREADS=1
USERNAME=admin@example.com
PASSWORD=change-me
DEBUG=false
LOG_LEVEL=INFO
CACHE_DIR=./data/cache

# Supabase settings for local self-hosted Supabase.
SUPABASE_URL=http://host.docker.internal:8000
SUPABASE_ANON_KEY=local-anon-key
SUPABASE_SERVICE_KEY=local-service-role-key
SUPABASE_QR_BUCKET=qr
SUPABASE_ARTICLES_BUCKET=article-images
SUPABASE_QR_PATH=wx/{uuid}.png
SUPABASE_ARTICLE_IMAGE_PATH=articles/{article_id}/{filename}
SUPABASE_QR_SIGN_EXPIRES=120

# LLM settings for local testing.
LLM_API_BASE=
LLM_MODEL=
LLM_API_KEY=
