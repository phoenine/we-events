# Docker Compose settings for Supabase online.
COMPOSE_PROJECT_NAME=we-events
THREADS=1
ARTICLE_COLLECTION_WORKER_ENABLED=true
GROUP_COLLECTION_SCHEDULER_ENABLED=true
USERNAME=admin@example.com
PASSWORD=change-me
DEBUG=false
LOG_LEVEL=INFO
CACHE_DIR=./data/cache

# Supabase settings for Supabase online.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=online-anon-key
SUPABASE_SERVICE_KEY=online-service-role-key
SUPABASE_QR_BUCKET=qr
SUPABASE_ARTICLES_BUCKET=article-images
SUPABASE_QR_PATH=wx/{uuid}.png
SUPABASE_ARTICLE_IMAGE_PATH=articles/{article_id}/{filename}
SUPABASE_QR_SIGN_EXPIRES=120

# LLM settings for online testing.
LLM_API_BASE=
LLM_MODEL=
LLM_API_KEY=
